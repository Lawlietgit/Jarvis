{
  "name": "jarvis-openclaw-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Task orchestration scaffold for OpenClaw-style web automations",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts run tasks/download_to_sheet.example.yaml --dry-run",
    "start": "node --enable-source-maps dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
